{
  "name": "ts-jest-test-generator",
  "version": "1.0.0",
  "description": "Automatically generates Jest unit test templates from TypeScript code analysis",
  "main": "dist/index.js",
  "bin": {
    "ts-jest-gen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "jest --forceExit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["typescript", "jest", "test-generator", "unit-tests", "openclaw"],
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
